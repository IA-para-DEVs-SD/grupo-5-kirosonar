# Application
NODE_ENV=development
APP_NAME=ERP Gráficas Expressas
APP_VERSION=1.0.0
LOG_LEVEL=debug

# API Gateway
API_GATEWAY_PORT=3000
API_GATEWAY_HOST=0.0.0.0

# Database - PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=erp_grafica
DB_USER=erp_user
DB_PASSWORD=erp_password_dev
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_password_dev
REDIS_DB=0

# Message Broker - RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# Elasticsearch
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=elastic_password_dev

# S3/MinIO
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_dev
MINIO_BUCKET_ARTS=arts
MINIO_BUCKET_DOCUMENTS=documents
MINIO_EXTERNAL_PORT=9010
MINIO_CONSOLE_PORT=9011

# JWT
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRATION=24h

# Microservices Ports
ORDER_SERVICE_PORT=3001
PRODUCTION_SERVICE_PORT=3002
MATERIAL_SERVICE_PORT=3003
RESOURCE_SERVICE_PORT=3004
QUALITY_SERVICE_PORT=3005
FINANCIAL_SERVICE_PORT=3006
CUSTOMER_SERVICE_PORT=3007
DELIVERY_SERVICE_PORT=3008
HR_SERVICE_PORT=3009
NOTIFICATION_SERVICE_PORT=3010
REPORTING_SERVICE_PORT=3011

# Backup
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *
BACKUP_DIR=/backups
ADMIN_EMAIL=

# Monitoring
SENTRY_DSN=
DATADOG_API_KEY=
